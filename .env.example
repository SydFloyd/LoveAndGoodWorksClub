DATABASE_URL=

# Common user password (required)
SITE_PASSWORD=
# Admin password (recommended to set differently and stronger)
SITE_PASSWORD_ADMIN=

# Optional explicit cookie tokens.
# If omitted, SITE_PASSWORD/SITE_PASSWORD_ADMIN values are used.
SITE_ACCESS_TOKEN_USER=
SITE_ACCESS_TOKEN_ADMIN=

# Backward-compatible aliases (optional)
SITE_PASSWORD_USER=
ADMIN_PASSWORD=
SITE_ACCESS_TOKEN=

# Public base URL (example: https://loveandgoodworks.org)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Calendar integration
# Option 1: provide calendar id (recommended)
GOOGLE_CALENDAR_ID=
# Required for fetching upcoming events from Google Calendar API
GOOGLE_CALENDAR_API_KEY=
# Optional direct embed URL (otherwise generated from GOOGLE_CALENDAR_ID)
GOOGLE_CALENDAR_EMBED_URL=
GOOGLE_CALENDAR_TIMEZONE=America/New_York
